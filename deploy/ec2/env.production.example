# Bird Dog production environment template for EC2
# Copy to /etc/bird-dog/.env.production on the EC2 host.

NODE_ENV=production
PORT=3000

# Public URL of your app (must be https in production)
APP_BASE_URL=https://app.your-domain.com

# Session and cookie settings
BIRD_DOG_SESSION_SECRET=replace-with-long-random-secret
BIRD_DOG_COOKIE_SECURE=true
BIRD_DOG_PREVIEW_UNLOCK_ALL=false
NEXT_PUBLIC_BIRD_DOG_PREVIEW_UNLOCK_ALL=false

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_REQUEST_TIMEOUT_MS=12000

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Optional login gate
BIRD_DOG_LOGIN_PASSCODE=

# Data mode / scraping
BIRD_DOG_DATA_MODE=imported
BIRD_DOG_ALLOW_PG_LIVE_SCRAPE=false
NEXT_PUBLIC_BIRD_DOG_MONITOR_INTERVAL_SECONDS=180
HARVEST_WORKER_POLL_SECONDS=15
RESIDENTIAL_PROXY_TEMPLATE_URLS=
SCRAPER_USER_AGENTS=

# Maps
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# OTA providers
BIRD_DOG_FLIGHT_PROVIDERS=amadeus,sabre
BIRD_DOG_FLIGHT_PROVIDER_ENDPOINT=
BIRD_DOG_FLIGHT_PROVIDER_API_KEY=

AMADEUS_BASE_URL=https://api.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_CURRENCY=USD
AMADEUS_ENABLE_LIVE_BOOKING=false

SABRE_BOOKING_API_URL=
SABRE_API_KEY=

BIRD_DOG_BUS_PROVIDERS=redbus,flixbus,bus
REDBUS_BOOKING_API_URL=
REDBUS_API_KEY=
FLIXBUS_BOOKING_API_URL=
FLIXBUS_API_KEY=
BUS_BOOKING_API_URL=
BUS_BOOKING_API_KEY=
