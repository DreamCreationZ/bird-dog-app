# Required for server-side session signing
BIRD_DOG_SESSION_SECRET=change-me
# Optional cookie security override for local production-mode testing
# true = always secure cookies, false = allow non-https localhost cookies
BIRD_DOG_COOKIE_SECURE=false
# Optional preview mode (disables tournament locks)
BIRD_DOG_PREVIEW_UNLOCK_ALL=false
NEXT_PUBLIC_BIRD_DOG_PREVIEW_UNLOCK_ALL=false

# Required for Supabase REST API access (app + worker)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_REQUEST_TIMEOUT_MS=12000

# Required for Stripe payment unlock flow
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
APP_BASE_URL=http://localhost:3000

# Optional: for advanced route optimization engine
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Worker polling interval in seconds
HARVEST_WORKER_POLL_SECONDS=15

# Data source mode:
# - imported (default): app reads imported Supabase data only
# - live: allow live PG scraper routes
BIRD_DOG_DATA_MODE=imported

# Live PG scraping safety switch (must be true + BIRD_DOG_DATA_MODE=live)
BIRD_DOG_ALLOW_PG_LIVE_SCRAPE=false
NEXT_PUBLIC_BIRD_DOG_MONITOR_INTERVAL_SECONDS=180

# Optional residential proxy templates (comma-separated)
# Each template must contain {url}
RESIDENTIAL_PROXY_TEMPLATE_URLS=

# Optional user-agent rotation list separated by ||
SCRAPER_USER_AGENTS=

# OTA booking integrations
# Flight providers list in priority order (comma-separated):
# amadeus,sabre or your custom provider keys
BIRD_DOG_FLIGHT_PROVIDERS=amadeus,sabre

# Optional custom generic flight provider endpoint
BIRD_DOG_FLIGHT_PROVIDER_ENDPOINT=
BIRD_DOG_FLIGHT_PROVIDER_API_KEY=

# Amadeus direct API config
AMADEUS_BASE_URL=https://test.api.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_CURRENCY=USD
# Set true only when you are ready to create real orders (not quote-only)
AMADEUS_ENABLE_LIVE_BOOKING=false

# Sabre booking adapter endpoint (typically your agency/middleware endpoint)
SABRE_BOOKING_API_URL=
SABRE_API_KEY=

# Ground/bus providers in priority order
BIRD_DOG_BUS_PROVIDERS=redbus,flixbus,bus
REDBUS_BOOKING_API_URL=
REDBUS_API_KEY=
FLIXBUS_BOOKING_API_URL=
FLIXBUS_API_KEY=
BUS_BOOKING_API_URL=
BUS_BOOKING_API_KEY=
