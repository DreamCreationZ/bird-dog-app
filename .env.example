# Required for server-side session signing
BIRD_DOG_SESSION_SECRET=change-me
# Optional additional sign-in password for coaches
BIRD_DOG_LOGIN_PASSCODE=
# Preferred name (same behavior as above if set)
BIRD_DOG_LOGIN_PASSWORD=
# Optional preview mode (disables tournament locks)
BIRD_DOG_PREVIEW_UNLOCK_ALL=false
NEXT_PUBLIC_BIRD_DOG_PREVIEW_UNLOCK_ALL=false

# Required for Supabase REST API access (app + worker)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Required for Stripe payment unlock flow
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
APP_BASE_URL=http://localhost:3000

# Optional: for advanced route optimization engine
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Worker polling interval in seconds
HARVEST_WORKER_POLL_SECONDS=15

# Optional residential proxy templates (comma-separated)
# Each template must contain {url}
RESIDENTIAL_PROXY_TEMPLATE_URLS=

# Optional user-agent rotation list separated by ||
SCRAPER_USER_AGENTS=
